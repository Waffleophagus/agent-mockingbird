#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(git rev-parse --show-toplevel)"
cd "${ROOT_DIR}"

staged_files="$(git diff --cached --name-only --diff-filter=ACMR)"
if [[ -z "${staged_files}" ]]; then
  exit 0
fi

should_build="false"
while IFS= read -r path; do
  case "${path}" in
    apps/*|packages/*|vendor/opencode/*|runtime-assets/*|drizzle/*|build.ts|build-bin.ts|build-cli.mjs|package.json|bun.lock|turbo.json|tsconfig.json|scripts/*|eslint.config.mjs)
      should_build="true"
      break
      ;;
  esac
done <<< "${staged_files}"

if [[ "${should_build}" != "true" ]]; then
  exit 0
fi

echo "[pre-commit] Running lint, typecheck, and artifact builds..."
bun run build:cli
bun run lint
bun run typecheck
bun run build
bun run build:bin

git add bin/agent-mockingbird dist/app
