{
  "compilerOptions": {
    "lib": ["ESNext", "DOM"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,

    // Bundler mode
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    // Best practices
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },

    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    ".opencode/tools/**/*.ts",
    "scripts/**/*.ts",
    "build.ts",
    "build-bin.ts",
    "bun-env.d.ts",
    "eslint.config.mjs",
    "drizzle.config.ts"
  ],
  "exclude": ["dist", "node_modules", "openclaw", "opencode", "opencode-sdk-js", "convex-backend", "rivet", "sandbox-agent"]
}
