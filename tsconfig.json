{
  "compilerOptions": {
    "lib": ["ESNext", "DOM"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "baseUrl": ".",
    "paths": {
      "@agent-mockingbird/contracts": ["./packages/contracts/src/index.ts"],
      "@agent-mockingbird/contracts/*": ["./packages/contracts/src/*"],
      "@agent-mockingbird/api": ["./packages/api/src/index.ts"],
      "@agent-mockingbird/api/*": ["./packages/api/src/*"],
      "@agent-mockingbird/app-core": ["./packages/app-core/src/index.ts"],
      "@agent-mockingbird/app-core/*": ["./packages/app-core/src/*"],
      "@streamdown/code": ["./vendor/streamdown/packages/streamdown-code/index.ts"],
      "@streamdown/code-native": ["./vendor/streamdown/packages/streamdown-code-native/index.ts"],
      "@streamdown/core": ["./vendor/streamdown/packages/streamdown-core/src/index.ts"],
      "@streamdown/react-native": ["./vendor/streamdown/packages/streamdown-react-native/index.tsx"],
      "streamdown": ["./vendor/streamdown/packages/streamdown/index.tsx"]
    },
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false
  },
  "include": [
    "scripts/**/*.ts",
    "build.ts",
    "build-bin.ts",
    "bun-env.d.ts",
    "eslint.config.mjs",
    "drizzle.config.ts"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "openclaw",
    "opencode",
    "opencode-sdk-js",
    "convex-backend",
    "rivet",
    "sandbox-agent"
  ]
}
