{
  "name": "agent-mockingbird",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.10",
  "bin": {
    "agent-mockingbird": "bin/agent-mockingbird"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel --filter=@agent-mockingbird/server --filter=@agent-mockingbird/mobile",
    "dev:server": "turbo run dev --filter=@agent-mockingbird/server",
    "dev:web": "turbo run dev --filter=@agent-mockingbird/server",
    "dev:mobile": "turbo run dev --filter=@agent-mockingbird/mobile",
    "dev:stack": "bun run build:web && bun run build:cli && bash scripts/dev-stack.sh",
    "build:cli": "bun run ./build-cli.mjs",
    "build:bin": "bun run ./build-bin.ts",
    "build:android": "bash ./apps/mobile/build-android.sh",
    "build": "turbo run build",
    "build:server": "turbo run build --filter=@agent-mockingbird/server",
    "build:web": "turbo run build --filter=@agent-mockingbird/web",
    "refresh:streamdown": "bash ./scripts/refresh-streamdown.sh",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "db:generate": "turbo run db:generate --filter=@agent-mockingbird/server",
    "db:migrate": "turbo run db:migrate --filter=@agent-mockingbird/server",
    "db:check": "turbo run db:check --filter=@agent-mockingbird/server",
    "db:wipe": "turbo run db:wipe --filter=@agent-mockingbird/server",
    "config:migrate-opencode-env": "bun run ./scripts/migrate-opencode-env.ts"
  },
  "overrides": {
    "@streamdown/cjk": "1.0.3",
    "@streamdown/code": "1.1.1",
    "@streamdown/code-native": "0.1.2",
    "@streamdown/core": "0.1.2",
    "@streamdown/math": "1.0.3",
    "@streamdown/mermaid": "1.0.3",
    "@streamdown/react-native": "0.1.2",
    "remend": "1.2.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.39.3",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.3.0",
    "turbo": "^2.5.8",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
