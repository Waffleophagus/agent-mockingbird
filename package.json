{
  "name": "wafflebot",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel --filter=@wafflebot/server --filter=@wafflebot/mobile",
    "dev:server": "turbo run dev --filter=@wafflebot/server",
    "dev:web": "turbo run dev --filter=@wafflebot/server",
    "dev:mobile": "turbo run dev --filter=@wafflebot/mobile",
    "build:android": "bash ./apps/mobile/build-android.sh",
    "build": "turbo run build",
    "build:server": "turbo run build --filter=@wafflebot/server",
    "build:web": "turbo run build --filter=@wafflebot/web",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "db:generate": "turbo run db:generate --filter=@wafflebot/server",
    "db:migrate": "turbo run db:migrate --filter=@wafflebot/server",
    "db:check": "turbo run db:check --filter=@wafflebot/server",
    "db:wipe": "turbo run db:wipe --filter=@wafflebot/server"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.39.3",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.3.0",
    "turbo": "^2.5.8",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
