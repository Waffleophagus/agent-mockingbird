{
  "name": "wafflebot",
  "version": "0.0.1",
  "bin": {
    "wafflebot": "bin/wafflebot"
  },
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "dev:stack": "bun run build:cli && bash scripts/dev-stack.sh",
    "start": "NODE_ENV=production bun src/index.ts",
    "build:cli": "bun run build-cli.mjs",
    "build": "bun run build:cli && bun run build.ts",
    "build:bin": "bun run build-bin.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/backend/db/migrate.ts",
    "db:check": "drizzle-kit check",
    "db:wipe": "bun run src/backend/db/wipe.ts",
    "config:migrate-opencode-env": "bun run scripts/migrate-opencode-env.ts",
    "memory:status": "bun run src/backend/memory/cli.ts status",
    "memory:sync": "bun run src/backend/memory/cli.ts sync",
    "memory:reindex": "bun run src/backend/memory/cli.ts reindex",
    "memory:search": "bun run src/backend/memory/cli.ts search",
    "memory:activity": "bun run src/backend/memory/cli.ts activity",
    "memory:lint": "bun run src/backend/memory/cli.ts lint",
    "memory:migrate-format": "bun run src/backend/memory/cli.ts migrate-format",
    "memory:e2e": "bash scripts/memory-e2e.sh",
    "memory:trace:e2e": "bash scripts/memory-trace-e2e.sh"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.39.3",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.3.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@opencode-ai/plugin": "^1.2.15",
    "@opencode-ai/sdk": "^1.2.15",
    "@streamdown/code": "^1.0.3",
    "@t3-oss/env-core": "^0.13.10",
    "bun-plugin-tailwind": "^0.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cron": "^4.4.0",
    "drizzle-orm": "^0.45.1",
    "jsonc-parser": "^3.3.1",
    "lucide-react": "^0.564.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sqlite-vec": "0.1.7-alpha.2",
    "streamdown": "^2.3.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  }
}
