# SQLite + runtime config path
# WAFFLEBOT_DB_PATH=./data/wafflebot.db
# WAFFLEBOT_CONFIG_PATH=./data/wafflebot.config.json

# OpenCode runtime defaults (used on first config bootstrap and as explicit missing-field defaults)
# WAFFLEBOT_OPENCODE_BASE_URL=http://127.0.0.1:4096
# WAFFLEBOT_OPENCODE_PROVIDER_ID=opencode
# WAFFLEBOT_OPENCODE_MODEL_ID=kimi-k2.5-free
# WAFFLEBOT_OPENCODE_MODEL_FALLBACKS=opencode/kimi-k2.5-free,openai/gpt-4.1-mini
# WAFFLEBOT_OPENCODE_SMALL_MODEL=opencode/kimi-k2.5-free
# WAFFLEBOT_OPENCODE_TIMEOUT_MS=120000
# WAFFLEBOT_OPENCODE_PROMPT_TIMEOUT_MS=300000
# WAFFLEBOT_OPENCODE_RUN_WAIT_TIMEOUT_MS=180000
# WAFFLEBOT_OPENCODE_DIRECTORY=.

# OpenCode auth (optional)
# WAFFLEBOT_OPENCODE_AUTH_HEADER=Bearer your-token
# WAFFLEBOT_OPENCODE_USERNAME=opencode
# WAFFLEBOT_OPENCODE_PASSWORD=your-password

# Tiered cron subsystem
# WAFFLEBOT_CRON_ENABLED=true
# WAFFLEBOT_CRON_SCHEDULER_POLL_MS=1000
# WAFFLEBOT_CRON_WORKER_POLL_MS=1000
# WAFFLEBOT_CRON_LEASE_MS=30000
# WAFFLEBOT_CRON_MAX_ENQUEUE_PER_JOB_TICK=25
# WAFFLEBOT_CRON_API_BASE_URL=http://127.0.0.1:3001

# Memory subsystem defaults (used on first config bootstrap and as explicit missing-field defaults)
# WAFFLEBOT_MEMORY_ENABLED=true
# WAFFLEBOT_MEMORY_WORKSPACE_DIR=./data/workspace
# WAFFLEBOT_MEMORY_EMBED_PROVIDER=ollama
# WAFFLEBOT_MEMORY_EMBED_MODEL=nomic-embed-text
# WAFFLEBOT_MEMORY_OLLAMA_BASE_URL=http://127.0.0.1:11434
# WAFFLEBOT_MEMORY_CHUNK_TOKENS=400
# WAFFLEBOT_MEMORY_CHUNK_OVERLAP=80
# WAFFLEBOT_MEMORY_MAX_RESULTS=6
# WAFFLEBOT_MEMORY_MIN_SCORE=0.25
# WAFFLEBOT_MEMORY_SYNC_COOLDOWN_MS=10000
# WAFFLEBOT_MEMORY_TOOL_MODE=hybrid

# Tool API base URLs used by OpenCode tools
# WAFFLEBOT_MEMORY_API_BASE_URL=http://127.0.0.1:3001
