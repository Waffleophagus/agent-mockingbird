# SQLite
# WAFFLEBOT_DB_PATH=./data/wafflebot.db

# OpenCode runtime settings
# WAFFLEBOT_OPENCODE_BASE_URL=http://127.0.0.1:4096
# WAFFLEBOT_OPENCODE_PROVIDER_ID=ollama
# WAFFLEBOT_OPENCODE_MODEL_ID=qwen3-coder
# WAFFLEBOT_OPENCODE_TIMEOUT_MS=120000
# WAFFLEBOT_OPENCODE_DIRECTORY=/absolute/path/to/project
# WAFFLEBOT_OPENCODE_AUTH_HEADER=Bearer your-token
# WAFFLEBOT_OPENCODE_USERNAME=opencode
# WAFFLEBOT_OPENCODE_PASSWORD=your-password

# Memory subsystem
# WAFFLEBOT_MEMORY_ENABLED=true
# WAFFLEBOT_MEMORY_WORKSPACE_DIR=./data/workspace
# WAFFLEBOT_MEMORY_EMBED_PROVIDER=ollama
# WAFFLEBOT_MEMORY_EMBED_MODEL=nomic-embed-text
# WAFFLEBOT_MEMORY_OLLAMA_BASE_URL=http://127.0.0.1:11434
# WAFFLEBOT_MEMORY_CHUNK_TOKENS=400
# WAFFLEBOT_MEMORY_CHUNK_OVERLAP=80
# WAFFLEBOT_MEMORY_MAX_RESULTS=6
# WAFFLEBOT_MEMORY_MIN_SCORE=0.25
# WAFFLEBOT_MEMORY_SYNC_COOLDOWN_MS=10000
# WAFFLEBOT_MEMORY_TOOL_MODE=hybrid
# WAFFLEBOT_MEMORY_WRITE_POLICY=conservative
# WAFFLEBOT_MEMORY_MIN_CONFIDENCE=0.7
# WAFFLEBOT_MEMORY_API_BASE_URL=http://127.0.0.1:3001
