+  const COMPACTION_BUFFER = 20_000
+
+  export function effectiveTokenCount(tokens: MessageV2.Assistant["tokens"]) {
+    return (
+      tokens.total ||
+      tokens.input + tokens.output + tokens.cache.read + tokens.cache.write
+    )
+  }
+
+  export async function usableInputBudget(input: { model: Provider.Model }) {
+    const config = await Config.get()
+    const context = input.model.limit.context
+    if (context === 0) return 0
+
+    const reserved =
+      config.compaction?.reserved ??
+      Math.min(COMPACTION_BUFFER, ProviderTransform.maxOutputTokens(input.model))
+    return input.model.limit.input
+      ? input.model.limit.input - reserved
+      : context - ProviderTransform.maxOutputTokens(input.model)
+  }
+
+  export async function shouldPreemptivelyCompact(input: {
+    tokens: MessageV2.Assistant["tokens"]
+    model: Provider.Model
+    idleMs: number
+    ratio: number
+  }) {
+    const config = await Config.get()
+    if (config.compaction?.auto === false) return false
+    const idleThreshold = config.compaction?.preemptiveIdleMs ?? 0
+    if (input.idleMs < idleThreshold) return false
+    const usable = await usableInputBudget({ model: input.model })
+    if (typeof usable !== "number" || usable <= 0) return false
+    return effectiveTokenCount(input.tokens) >= usable * input.ratio
+  }
+
+  export async function isOverflow(input: { tokens: MessageV2.Assistant["tokens"]; model: Provider.Model }) {
+    const config = await Config.get()
+    if (config.compaction?.auto === false) return false
+    const usable = await usableInputBudget({ model: input.model })
+    if (typeof usable !== "number" || usable <= 0) return false
+    return effectiveTokenCount(input.tokens) >= usable
+  }
   export const PRUNE_MINIMUM = 20_000
   export const PRUNE_PROTECT = 40_000
   const PRUNE_PROTECTED_TOOLS = ["skill"]
