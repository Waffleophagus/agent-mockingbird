--- /dev/null
+++ b/packages/app/src/components/settings-heartbeat.test.ts
@@ -0,0 +1,31 @@
+import { describe, expect, test } from "bun:test"
+import { resolveHeartbeatAgentOptions } from "./settings-heartbeat-options"
+
+describe("resolveHeartbeatAgentOptions", () => {
+  test("removes built-in defaults when the API marks them unavailable", () => {
+    const options = resolveHeartbeatAgentOptions([
+      { id: "build", disable: true },
+      { id: "plan", hidden: true },
+      { id: "review", mode: "all" },
+      { id: "worker", mode: "subagent" },
+    ])
+
+    expect(options).toEqual(["review"])
+  })
+
+  test("keeps built-in defaults when the API omits them", () => {
+    const options = resolveHeartbeatAgentOptions([{ id: "review", mode: "all" }])
+
+    expect(options).toEqual(["build", "plan", "review"])
+  })
+
+  test("keeps built-in defaults when the API explicitly allows them", () => {
+    const options = resolveHeartbeatAgentOptions([
+      { id: "plan", mode: "all" },
+      { id: "build", mode: "primary" },
+      { id: "review", mode: "all" },
+    ])
+
+    expect(options).toEqual(["build", "plan", "review"])
+  })
+})
