From 9d8d757c11df46e0467fc34d57f73d2a3bc11c40 Mon Sep 17 00:00:00 2001
From: Matt Campbell <matt@battleshopper.com>
Date: Sun, 22 Mar 2026 00:14:20 -0500
Subject: [PATCH 13/15] feat: add executor sidebar entry

---
 packages/app/src/pages/layout.tsx               |  2 ++
 packages/app/src/pages/layout/sidebar-shell.tsx | 11 +++++++++++
 2 files changed, 13 insertions(+)

diff --git a/packages/app/src/pages/layout.tsx b/packages/app/src/pages/layout.tsx
index 109eb5e35..25069a011 100644
--- a/packages/app/src/pages/layout.tsx
+++ b/packages/app/src/pages/layout.tsx
@@ -2350,6 +2350,8 @@ export default function Layout(props: ParentProps) {
       renderProjectOverlay={projectOverlay}
       usageLabel={() => "Usage"}
       onOpenUsage={() => window.location.assign("/usage")}
+      executorLabel={() => "Executor"}
+      onOpenExecutor={() => window.location.assign("/executor")}
       settingsLabel={() => language.t("sidebar.settings")}
       settingsKeybind={() => command.keybind("settings.open")}
       onOpenSettings={openSettings}
diff --git a/packages/app/src/pages/layout/sidebar-shell.tsx b/packages/app/src/pages/layout/sidebar-shell.tsx
index 47df7f298..655e5f3ca 100644
--- a/packages/app/src/pages/layout/sidebar-shell.tsx
+++ b/packages/app/src/pages/layout/sidebar-shell.tsx
@@ -27,6 +27,8 @@ export const SidebarContent = (props: {
   renderProjectOverlay: () => JSX.Element
   usageLabel: Accessor<string>
   onOpenUsage: () => void
+  executorLabel: Accessor<string>
+  onOpenExecutor: () => void
   settingsLabel: Accessor<string>
   settingsKeybind: Accessor<string | undefined>
   onOpenSettings: () => void
@@ -82,6 +84,15 @@ export const SidebarContent = (props: {
               aria-label={props.usageLabel()}
             />
           </Tooltip>
+          <Tooltip placement={placement()} value={props.executorLabel()}>
+            <IconButton
+              icon="mcp"
+              variant="ghost"
+              size="large"
+              onClick={props.onOpenExecutor}
+              aria-label={props.executorLabel()}
+            />
+          </Tooltip>
           <TooltipKeybind placement={placement()} title={props.settingsLabel()} keybind={props.settingsKeybind() ?? ""}>
             <IconButton
               icon="settings-gear"
