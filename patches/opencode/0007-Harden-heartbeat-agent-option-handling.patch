new file mode 100644
index 000000000..786d1f824
--- /dev/null
+++ b/packages/app/src/components/settings-heartbeat-options.ts
@@ -0,0 +1,31 @@
+type AgentType = {
+  id: string
+  mode?: string
+  hidden?: boolean
+  disable?: boolean
+}
+
+export const DEFAULT_HEARTBEAT_AGENT_OPTIONS = ["build", "plan"]
+
+function isSelectableHeartbeatAgent(item: AgentType) {
+  return item.mode !== "subagent" && item.hidden !== true && item.disable !== true
+}
+
+export function resolveHeartbeatAgentOptions(
+  agentTypes: AgentType[],
+  defaults: string[] = DEFAULT_HEARTBEAT_AGENT_OPTIONS,
+) {
+  const byId = new Map(agentTypes.map((item) => [item.id, item] as const))
+  const ids = new Set(agentTypes.filter(isSelectableHeartbeatAgent).map((item) => item.id))
+
+  for (const defaultId of defaults) {
+    const item = byId.get(defaultId)
+    if (!item || isSelectableHeartbeatAgent(item)) {
+      ids.add(defaultId)
+    }
+  }
+
+  return [...ids].sort((left, right) => left.localeCompare(right))
+}
+
+export type { AgentType }
diff --git a/packages/app/src/components/settings-heartbeat.test.ts b/packages/app/src/components/settings-heartbeat.test.ts
