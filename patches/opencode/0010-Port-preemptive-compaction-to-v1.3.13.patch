   hash: string
   path: string
-  config: {
-    workspace: {
-      pinnedDirectory: string
-    }
-    runtime: Record<string, unknown>
+  config: RuntimeConfig
+}
+
+type CompactionFormState = {
+  preemptiveIdleMinutes: string
+  preemptiveThresholdPercent: string
+  memoryAutoPersist: boolean
+}
+
+function toCompactionForm(config: RuntimeConfig): CompactionFormState {
+  const compaction = config.runtime.opencode?.compaction
+  return {
+    preemptiveIdleMinutes: String(compaction?.preemptiveIdleMinutes ?? 15),
+    preemptiveThresholdPercent: String(Math.round((compaction?.preemptiveThresholdRatio ?? 0.6) * 100)),
+    memoryAutoPersist: compaction?.memoryAutoPersist ?? true,
+  }
+}
+
+function buildCompactionPatch(form: CompactionFormState) {
+  const preemptiveIdleMinutes = Number(form.preemptiveIdleMinutes)
+  const preemptiveThresholdPercent = Number(form.preemptiveThresholdPercent)
+
+  if (!Number.isFinite(preemptiveIdleMinutes) || preemptiveIdleMinutes < 0) {
+    throw new Error("Preemptive idle threshold must be 0 or greater")
+  }
+  if (
+    !Number.isFinite(preemptiveThresholdPercent) ||
+    preemptiveThresholdPercent < 0 ||
+    preemptiveThresholdPercent > 100
+  ) {
+    throw new Error("Preemptive compaction threshold must be between 0 and 100")
+  }
+
+  return {
+    preemptiveIdleMinutes,
+    preemptiveThresholdRatio: preemptiveThresholdPercent / 100,
+    memoryAutoPersist: form.memoryAutoPersist,
   }
 }
 
