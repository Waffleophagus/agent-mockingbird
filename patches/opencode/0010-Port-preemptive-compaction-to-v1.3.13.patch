 import type { MessageV2 } from "./message-v2"
 
 const COMPACTION_BUFFER = 20_000
+const DEFAULT_PREEMPTIVE_THRESHOLD_RATIO = 0.6
 
-export function isOverflow(input: { cfg: Config.Info; tokens: MessageV2.Assistant["tokens"]; model: Provider.Model }) {
-  if (input.cfg.compaction?.auto === false) return false
-  const context = input.model.limit.context
-  if (context === 0) return false
+function inputHasNumber(value: unknown): value is number {
+  return typeof value === "number" && Number.isFinite(value)
+}
 
-  const count =
-    input.tokens.total || input.tokens.input + input.tokens.output + input.tokens.cache.read + input.tokens.cache.write
+export function effectiveTokenCount(tokens: MessageV2.Assistant["tokens"]) {
+  return tokens.total || tokens.input + tokens.output + tokens.cache.read + tokens.cache.write
+}
+
+export function usableInputBudget(input: { cfg: Config.Info; model: Provider.Model }) {
+  const context = input.model.limit.context
+  if (context === 0) return 0
 
   const reserved =
     input.cfg.compaction?.reserved ?? Math.min(COMPACTION_BUFFER, ProviderTransform.maxOutputTokens(input.model))
-  const usable = input.model.limit.input
+
+  return typeof input.model.limit.input === "number"
     ? input.model.limit.input - reserved
     : context - ProviderTransform.maxOutputTokens(input.model)
-  return count >= usable
+}
+
+export function shouldPreemptivelyCompact(input: {
+  cfg: Config.Info
+  tokens: MessageV2.Assistant["tokens"]
+  model: Provider.Model
+  idleMs: number
+  ratio?: number
+}) {
+  if (input.cfg.compaction?.auto === false) return false
+  const idleThreshold = input.cfg.compaction?.preemptiveIdleMs ?? 0
+  if (input.idleMs < idleThreshold) return false
+
+  const usable = usableInputBudget({ cfg: input.cfg, model: input.model })
+  if (usable <= 0) return false
+
+  const ratio = inputHasNumber(input.ratio)
+    ? input.ratio
+    : (input.cfg.compaction?.preemptiveThresholdRatio ?? DEFAULT_PREEMPTIVE_THRESHOLD_RATIO)
+
+  return effectiveTokenCount(input.tokens) >= usable * ratio
+}
+
+export function isOverflow(input: { cfg: Config.Info; tokens: MessageV2.Assistant["tokens"]; model: Provider.Model }) {
+  if (input.cfg.compaction?.auto === false) return false
+  const usable = usableInputBudget({ cfg: input.cfg, model: input.model })
+  if (usable <= 0) return false
+  return effectiveTokenCount(input.tokens) >= usable
 }
