   const [state, setState] = createStore({
     loading: true,
     saving: false,
@@ -148,6 +160,7 @@ export const SettingsHeartbeat: Component = () => {
     error: "",
     runtimeHash: "",
     runtimePath: "",
+    agentOptions: [] as string[],
     status: null as HeartbeatStatus | null,
