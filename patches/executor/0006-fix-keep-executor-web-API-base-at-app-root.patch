 import { SecretsPage } from "./views/secrets";
 import { AddSourcePage } from "./views/add-source";
-import { getExecutorApiBaseUrl } from "./lib/urls";
+import { getExecutorUiBaseUrl } from "./lib/urls";
 
 // ---------------------------------------------------------------------------
 // Route search schema
@@ -32,7 +32,7 @@ const sourceTabs = ["model", "discover"] as const;
 const executorBasePath = (import.meta.env.BASE_URL ?? "/").replace(/\/+$/, "") || "/";
 
 if (typeof window !== "undefined") {
-  setExecutorApiBaseUrl(getExecutorApiBaseUrl(import.meta.env.BASE_URL ?? "/", window.location.origin));
+  setExecutorApiBaseUrl(getExecutorUiBaseUrl(import.meta.env.BASE_URL ?? "/", window.location.origin));
 }
 
