@@ -0,0 +1,197 @@
+import { createHash } from "node:crypto";
+import { extname, join } from "node:path";
+import { FileSystem } from "@effect/platform";
+import { NodeFileSystem } from "@effect/platform-node";
+import type { OpenApiSpecUploadStorage } from "@executor/plugin-openapi-sdk";
+import {
+  OpenApiSpecUploadResultSchema,
+  buildOpenApiUploadedSpecUrl,
+  parseOpenApiUploadedSpecUrl,
+  type OpenApiSpecUploadResult,
+} from "@executor/plugin-openapi-shared";
+import * as Effect from "effect/Effect";
+import * as Schema from "effect/Schema";
+
+const decodeUploadRecord = Schema.decodeUnknownSync(OpenApiSpecUploadResultSchema);
+const encodeUploadRecord = Schema.encodeSync(OpenApiSpecUploadResultSchema);
+
+const toError = (cause: unknown): Error =>
+  cause instanceof Error ? cause : new Error(String(cause));
+
+const bindNodeFileSystem = <A, E>(
+  effect: Effect.Effect<A, E, FileSystem.FileSystem>,
+): Effect.Effect<A, E, never> =>
+  effect.pipe(Effect.provide(NodeFileSystem.layer));
+
+const sha256ForText = (text: string): string =>
+  createHash("sha256").update(text, "utf8").digest("hex");
+
+const contentPath = (input: {
+  rootDir: string;
+  sha256: string;
+  filename: string;
+}): string =>
+  join(input.rootDir, `${input.sha256}.document${extname(input.filename).toLowerCase()}`);
+
+const metadataPath = (input: {
+  rootDir: string;
+  sha256: string;
+}): string => join(input.rootDir, `${input.sha256}.json`);
+
+const createUploadRecord = (input: {
+  filename: string;
+  contentType: string | null;
+  text: string;
+  sha256: string;
+}): OpenApiSpecUploadResult => ({
+  specUrl: buildOpenApiUploadedSpecUrl({
+    sha256: input.sha256,
+    filename: input.filename,
+  }),
+  filename: input.filename,
+  contentType: input.contentType,
+  sizeBytes: Buffer.byteLength(input.text, "utf8"),
+  sha256: input.sha256,
+});
+
+const readUploadRecord = (path: string): Effect.Effect<OpenApiSpecUploadResult | null, Error, never> =>
+  bindNodeFileSystem(
+    Effect.gen(function* () {
+      const fileSystem = yield* FileSystem.FileSystem;
+      const exists = yield* fileSystem.exists(path).pipe(Effect.mapError(toError));
+      if (!exists) {
+        return null;
+      }
+
+      const contents = yield* fileSystem.readFileString(path, "utf8").pipe(
+        Effect.mapError(toError),
+      );
+      return decodeUploadRecord(JSON.parse(contents));
+    }),
+  );
+
+const createInMemoryOpenApiUploadStorage = (): OpenApiSpecUploadStorage => {
+  const recordsByHash = new Map<string, OpenApiSpecUploadResult>();
+  const textBySpecUrl = new Map<string, string>();
+
+  return {
+    put: ({ filename, contentType, text }) =>
+      Effect.sync(() => {
+        const sha256 = sha256ForText(text);
+        const existing = recordsByHash.get(sha256);
+        if (existing) {
+          textBySpecUrl.set(existing.specUrl, text);
+          return existing;
+        }
+
+        const record = createUploadRecord({
+          filename,
+          contentType,
+          text,
+          sha256,
+        });
+        recordsByHash.set(sha256, record);
+        textBySpecUrl.set(record.specUrl, text);
+        return record;
+      }),
+    getBySpecUrl: (specUrl) =>
+      Effect.sync(() => textBySpecUrl.get(specUrl) ?? null),
+    getMetadataBySpecUrl: (specUrl) =>
+      Effect.sync(() => {
+        for (const record of recordsByHash.values()) {
+          if (record.specUrl === specUrl) {
+            return record;
+          }
+        }
+        return null;
+      }),
+  };
+};
+
+export const createFileOpenApiUploadStorage = (input: {
+  rootDir: string;
+}): OpenApiSpecUploadStorage =>
+  input.rootDir === ":memory:"
+    ? createInMemoryOpenApiUploadStorage()
+    : {
+        put: ({ filename, contentType, text }) =>
+          bindNodeFileSystem(
+            Effect.gen(function* () {
+              const fileSystem = yield* FileSystem.FileSystem;
+              const sha256 = sha256ForText(text);
+              const metadata = metadataPath({
+                rootDir: input.rootDir,
+                sha256,
+              });
+              const existing = yield* readUploadRecord(metadata);
+              if (existing) {
+                return existing;
+              }
+
+              const record = createUploadRecord({
+                filename,
+                contentType,
+                text,
+                sha256,
+              });
+              const content = contentPath({
+                rootDir: input.rootDir,
+                sha256,
+                filename: record.filename,
+              });
+
+              yield* fileSystem.makeDirectory(input.rootDir, {
+                recursive: true,
+              }).pipe(Effect.mapError(toError));
+              yield* fileSystem.writeFileString(content, text).pipe(
+                Effect.mapError(toError),
+              );
+              yield* fileSystem.writeFileString(
+                metadata,
+                `${JSON.stringify(encodeUploadRecord(record), null, 2)}\n`,
+              ).pipe(Effect.mapError(toError));
+
+              return record;
+            }),
+          ),
+        getBySpecUrl: (specUrl) =>
+          bindNodeFileSystem(
+            Effect.gen(function* () {
+              const fileSystem = yield* FileSystem.FileSystem;
+              const parsed = parseOpenApiUploadedSpecUrl(specUrl);
+              if (parsed === null) {
+                return null;
+              }
+
+              const path = contentPath({
+                rootDir: input.rootDir,
+                sha256: parsed.sha256,
+                filename: parsed.filename,
+              });
+              const exists = yield* fileSystem.exists(path).pipe(Effect.mapError(toError));
+              if (!exists) {
+                return null;
+              }
+
+              return yield* fileSystem.readFileString(path, "utf8").pipe(
+                Effect.mapError(toError),
+              );
+            }),
+          ),
+        getMetadataBySpecUrl: (specUrl) =>
+          bindNodeFileSystem(
+            Effect.gen(function* () {
+              const parsed = parseOpenApiUploadedSpecUrl(specUrl);
+              if (parsed === null) {
+                return null;
+              }
+
+              return yield* readUploadRecord(
+                metadataPath({
+                  rootDir: input.rootDir,
+                  sha256: parsed.sha256,
+                }),
+              );
+            }),
+          ),
+      };
