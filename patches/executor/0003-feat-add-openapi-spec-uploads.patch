--- /dev/null
+++ b/packages/platform/sdk/src/runtime/openapi-spec-uploads.ts
@@ -0,0 +1,78 @@
+const OPENAPI_UPLOAD_URL_PROTOCOL = "executor-upload:";
+const OPENAPI_UPLOAD_URL_PREFIX = "executor-upload://openapi/";
+const OPENAPI_UPLOAD_FILENAME_FALLBACK = "openapi";
+
+const OPENAPI_UPLOAD_SHA256_PATTERN = /^[a-f0-9]{64}$/;
+
+export type OpenApiUploadedSpecUrlParts = {
+  sha256: string;
+  filename: string;
+};
+
+const sanitizeFilenameSegment = (value: string): string => {
+  const trimmed = value.trim();
+  const normalized = trimmed
+    .replaceAll("\\", "/")
+    .split("/")
+    .filter((segment) => segment.length > 0)
+    .at(-1)
+    ?? OPENAPI_UPLOAD_FILENAME_FALLBACK;
+  const sanitized = normalized
+    .replace(/[^A-Za-z0-9._-]+/g, "-")
+    .replace(/^-+|-+$/g, "");
+
+  return sanitized.length > 0 ? sanitized : OPENAPI_UPLOAD_FILENAME_FALLBACK;
+};
+
+export const buildOpenApiUploadedSpecUrl = (input: {
+  sha256: string;
+  filename: string;
+}): string =>
+  `${OPENAPI_UPLOAD_URL_PREFIX}${input.sha256}/${sanitizeFilenameSegment(input.filename)}`;
+
+export const parseOpenApiUploadedSpecUrl = (
+  specUrl: string,
+): OpenApiUploadedSpecUrlParts | null => {
+  if (!specUrl.startsWith(OPENAPI_UPLOAD_URL_PREFIX)) {
+    return null;
+  }
+
+  let parsed: URL;
+  try {
+    parsed = new URL(specUrl);
+  } catch {
+    return null;
+  }
+
+  if (parsed.protocol !== OPENAPI_UPLOAD_URL_PROTOCOL || parsed.hostname !== "openapi") {
+    return null;
+  }
+
+  const segments = parsed.pathname
+    .split("/")
+    .filter((segment) => segment.length > 0);
+  if (segments.length !== 2) {
+    return null;
+  }
+
+  const [sha256, filename] = segments;
+  if (!OPENAPI_UPLOAD_SHA256_PATTERN.test(sha256)) {
+    return null;
+  }
+
+  const sanitizedFilename = sanitizeFilenameSegment(filename);
+  if (sanitizedFilename !== filename) {
+    return null;
+  }
+
+  return {
+    sha256,
+    filename,
+  };
+};
+
+export const isOpenApiUploadedSpecUrl = (specUrl: string): boolean =>
+  parseOpenApiUploadedSpecUrl(specUrl) !== null;
+
+export const getOpenApiUploadedSpecFilename = (specUrl: string): string | null =>
+  parseOpenApiUploadedSpecUrl(specUrl)?.filename ?? null;
