index 0000000000000000000000000000000000000000..ec87afd2ea89fb6e5a35ebb7b86b5a7fa5bfb668
--- /dev/null
+++ b/packages/platform/sdk/src/runtime/sources/source-adapters/openapi.test.ts
@@ -0,0 +1,94 @@
+import { describe, expect, it } from "@effect/vitest";
+import { SourceIdSchema } from "#schema";
+import * as Effect from "effect/Effect";
+
+import { openApiSourceAdapter } from "@executor/source-openapi";
+import { createSourceFromPayload } from "../source-definitions";
+import { runtimeEffectError } from "../../effect-errors";
+
+describe("openapi source adapter", () => {
+  it.effect("syncs catalogs from uploaded pseudo URLs via the opaque resolver", () =>
+    Effect.gen(function* () {
+      const source = yield* createSourceFromPayload({
+        scopeId: "ws_test" as any,
+        sourceId: SourceIdSchema.make("src_openapi_uploaded_spec"),
+        payload: {
+          name: "Uploaded Demo",
+          kind: "openapi",
+          endpoint: "https://api.example.test",
+          namespace: "uploaded.demo",
+          binding: {
+            specUrl:
+              "executor-upload://openapi/aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa/demo.yaml",
+            defaultHeaders: null,
+          },
+          importAuthPolicy: "reuse_runtime",
+          importAuth: { kind: "none" },
+          auth: { kind: "none" },
+          status: "connected",
+          enabled: true,
+        },
+        now: Date.now(),
+      });
+
+      const syncResult = yield* openApiSourceAdapter.syncCatalog({
+        source,
+        resolveSecretMaterial: () =>
+          Effect.fail(
+            runtimeEffectError(
+              "sources/source-adapters/openapi.test",
+              "unexpected secret lookup",
+            ),
+          ),
+        resolveAuthMaterialForSlot: () =>
+          Effect.succeed({
+            placements: [],
+            headers: {},
+            queryParams: {},
+            cookies: {},
+            bodyValues: {},
+            expiresAt: null,
+            refreshAfter: null,
+          }),
+        resolveOpaqueDocumentUrl: (url) =>
+          Effect.succeed(
+            url ===
+                "executor-upload://openapi/aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa/demo.yaml"
+              ? JSON.stringify({
+                  openapi: "3.1.0",
+                  info: {
+                    title: "Uploaded Demo",
+                    version: "1.0.0",
+                  },
+                  servers: [
+                    {
+                      url: "https://wrong.example.test/v99",
+                    },
+                  ],
+                  paths: {
+                    "/widgets": {
+                      get: {
+                        operationId: "widgets.list",
+                        responses: {
+                          "200": {
+                            description: "ok",
+                          },
+                        },
+                      },
+                    },
+                  },
+                })
+              : null,
+          ),
+      });
+
+      const documents = Object.values(syncResult.fragment.documents ?? {});
+
+      expect(documents).toHaveLength(1);
+      expect(documents[0]?.rawRef).toBe(
+        "executor-upload://openapi/aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa/demo.yaml",
+      );
+      expect(Object.keys(syncResult.fragment.executables ?? {})).not.toHaveLength(0);
+    }),
+  );
+});
