+describe("executor platform API client wrapper", () => {
+  const expectWrappedSourceList = (count: number) =>
+    Effect.promise(async () => {
+      const apiServer = await startControlPlaneServer();
+
+      try {
+        const installation = await getInstallation(apiServer.baseUrl);
+        for (let index = 0; index < count; index += 1) {
+          await seedStoredOpenApiSource({
+            server: apiServer,
+            installation,
+            name: `Source ${index + 1}`,
+          });
+        }
+
+        const client = await createExecutorApiClient({
+          baseUrl: apiServer.baseUrl,
+          accountId: installation.actorScopeId,
+        });
+        const raw = await listSourcesRaw({
+          baseUrl: apiServer.baseUrl,
+          installation,
+        });
+        const wrapped = await client.sources.list({
+          path: {
+            workspaceId: installation.scopeId,
+          },
+        });
+
+        expect(Array.isArray(wrapped)).toBe(true);
+        expect(wrapped).toHaveLength(count);
+        expect(wrapped.map((source) => source.id)).toEqual(raw.map((source) => source.id));
+      } finally {
+        await apiServer.close();
+      }
+    });
+
+  it.effect("returns both sources when the server responds with exactly two items", () =>
+    expectWrappedSourceList(2));
+
+  it.effect("returns a one-item source list unchanged", () =>
+    expectWrappedSourceList(1));
+
+  it.effect("returns a three-item source list unchanged", () =>
+    expectWrappedSourceList(3));
+
+  it.effect("returns both secrets when the server responds with exactly two items", () =>
+    Effect.promise(async () => {
+      const apiServer = await startControlPlaneServer();
+
+      try {
+        await seedSecret(apiServer.baseUrl, "First Secret");
+        await seedSecret(apiServer.baseUrl, "Second Secret");
+
+        const client = await createExecutorApiClient({
+          baseUrl: apiServer.baseUrl,
+        });
+        const raw = await listSecretsRaw(apiServer.baseUrl);
+        const wrapped = await client.local.listSecrets({});
+
+        expect(Array.isArray(wrapped)).toBe(true);
+        expect(wrapped).toHaveLength(2);
+        expect(wrapped.map((secret) => secret.id)).toEqual(raw.map((secret) => secret.id));
+      } finally {
+        await apiServer.close();
+      }
+    }));
+});
+
 
