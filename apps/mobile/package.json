{
  "name": "@agent-mockingbird/mobile",
  "private": true,
  "version": "0.0.1",
  "main": "expo-router/entry",
  "scripts": {
    "preandroid": "bun ./scripts/reset-android-autolinking.mjs",
    "dev": "expo start --dev-client",
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "build:android:dev": "bunx eas build --profile development:device --platform android --local",
    "build:android:preview": "bunx eas build --profile preview:device --platform android --local",
    "build:android:prod": "bunx eas build --profile production --platform android --local",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "build:android": "./build-android.sh"
  },
  "dependencies": {
    "@agent-mockingbird/api": "workspace:*",
    "@agent-mockingbird/app-core": "workspace:*",
    "@agent-mockingbird/contracts": "workspace:*",
    "@expo/vector-icons": "^15.0.3",
    "@streamdown/code-native": "0.1.2",
    "@streamdown/core": "0.1.2",
    "@streamdown/react-native": "0.1.2",
    "expo": "~54.0.0",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-font": "~14.0.11",
    "expo-linking": "~8.0.11",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "lucide-react-native": "^0.564.0",
    "mobx": "^6.13.7",
    "mobx-state-tree": "^7.0.2",
    "nativewind": "^4.1.23",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-keyboard-controller": "1.18.5",
    "react-native-mmkv": "3.3.3",
    "react-native-nitro-modules": "^0.31.4",
    "react-native-reanimated": "4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-shiki-engine": "^0.3.9",
    "react-native-svg": "15.12.1",
    "react-native-worklets": "0.5.1",
    "shiki": "^3.23.0"
  },
  "devDependencies": {
    "@babel/core": "^7.28.4",
    "@types/react": "~19.1.10",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3"
  }
}
