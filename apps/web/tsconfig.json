      "@streamdown/code-native": ["../../vendor/streamdown/packages/streamdown-code-native/dist/index.d.ts"],
      "@streamdown/core": ["../../vendor/streamdown/packages/streamdown-core/dist/index.d.ts"],
      "@streamdown/react-native": ["../../vendor/streamdown/packages/streamdown-react-native/dist/index.d.ts"],
